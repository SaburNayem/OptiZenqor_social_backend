generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppUser {
  id                  String               @id @map("id")
  name                String               @map("name")
  username            String               @unique @map("username")
  email               String               @unique @map("email")
  avatar              String               @map("avatar")
  bio                 String               @map("bio")
  interests           Json                 @default("[]") @map("interests")
  role                String               @map("role")
  verification        String               @map("verification")
  status              String               @map("status")
  followers           Int                  @default(0) @map("followers")
  following           Int                  @default(0) @map("following")
  walletSummary       String               @map("wallet_summary")
  health              String               @map("health")
  reports             String               @map("reports")
  lastActive          String               @map("last_active")
  emailVerified       Boolean              @default(false) @map("email_verified")
  blocked             Boolean              @default(false) @map("blocked")
  passwordHash        String               @map("password_hash")
  website             String               @default("") @map("website")
  location            String               @default("") @map("location")
  coverImageUrl       String               @default("") @map("cover_image_url")
  isPrivate           Boolean              @default(false) @map("is_private")
  note                String?              @map("note")
  notePrivacy         String               @default("followers") @map("note_privacy")
  supporterBadge      Boolean              @default(false) @map("supporter_badge")
  createdAt           DateTime             @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt           DateTime             @default(now()) @db.Timestamptz(6) @map("updated_at")
  sessions            AuthSession[]
  sentFollowRelations AppFollowRelation[]  @relation("FollowerUser")
  targetFollowRelations AppFollowRelation[] @relation("TargetUser")
  posts               AppPost[]
  postReactions       AppPostReaction[]
  postComments        AppPostComment[]
  postCommentReactions AppPostCommentReaction[]
  threadParticipants  ChatThreadParticipant[]
  sentMessages        ChatMessage[]
  notifications       AppNotification[]
  buddyRequestsSent   BuddyRequest[]       @relation("BuddyRequester")
  buddyRequestsReceived BuddyRequest[]     @relation("BuddyTarget")
  buddyResponses      BuddyRequest[]       @relation("BuddyResponder")
  buddyRelationsA     BuddyRelation[]      @relation("BuddyUserA")
  buddyRelationsB     BuddyRelation[]      @relation("BuddyUserB")
  stories             Story[]
  storyComments       StoryComment[]
  storyReactions      StoryReaction[]
  storyViews          StoryView[]
  reels               Reel[]
  reelComments        ReelComment[]
  reelReactions       ReelReaction[]
  mediaUploads        MediaUpload[]
  bookmarks           Bookmark[]
  blockedUsers        UserBlock[]          @relation("BlockActor")
  blockedByUsers      UserBlock[]          @relation("BlockTarget")
  submittedReports    UserReport[]         @relation("ReportReporter")
  targetReports       UserReport[]         @relation("ReportTargetUser")
  settings            UserSettings?
  privacy             UserPrivacy?
  drafts              PostDraft[]
  scheduledPosts      ScheduledPost[]
  collections         Collection[]
  marketplaceProducts MarketplaceProduct[]
  marketplaceOrders   MarketplaceOrder[]   @relation("OrderBuyer")
  soldOrders          MarketplaceOrder[]   @relation("OrderSeller")
  postedJobs          Job[]
  jobApplications     JobApplication[]
  createdEvents       Event[]              @relation("EventOrganizer")
  eventRsvps          EventRsvp[]
  ownedCommunities    Community[]
  communityMemberships CommunityMember[]
  subscriptions       Subscription[]

  @@map("app_users")
}

model AuthCode {
  email     String   @map("email")
  purpose   String   @map("purpose")
  code      String   @map("code")
  expiresAt DateTime @db.Timestamptz(6) @map("expires_at")
  createdAt DateTime @db.Timestamptz(6) @map("created_at")

  @@id([email, purpose])
  @@map("auth_codes")
}

model AuthSession {
  sessionId         String   @id @map("session_id")
  userId            String   @map("user_id")
  accessToken       String   @unique @map("access_token")
  refreshToken      String   @unique @map("refresh_token")
  createdAt         DateTime @db.Timestamptz(6) @map("created_at")
  accessExpiresAt   DateTime @db.Timestamptz(6) @map("access_expires_at")
  refreshExpiresAt  DateTime @db.Timestamptz(6) @map("refresh_expires_at")
  user              AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model AppFollowRelation {
  followerId String   @map("follower_id")
  targetId   String   @map("target_id")
  createdAt  DateTime @db.Timestamptz(6) @map("created_at")
  follower   AppUser  @relation("FollowerUser", fields: [followerId], references: [id], onDelete: Cascade)
  target     AppUser  @relation("TargetUser", fields: [targetId], references: [id], onDelete: Cascade)

  @@id([followerId, targetId])
  @@map("app_follow_relations")
}

model BuddyRequest {
  id          String    @id @map("id")
  requesterId String    @map("requester_id")
  targetId    String    @map("target_id")
  status      String    @default("pending") @map("status")
  createdAt   DateTime  @db.Timestamptz(6) @map("created_at")
  respondedAt DateTime? @db.Timestamptz(6) @map("responded_at")
  respondedBy String?   @map("responded_by")
  requester   AppUser   @relation("BuddyRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  target      AppUser   @relation("BuddyTarget", fields: [targetId], references: [id], onDelete: Cascade)
  responder   AppUser?  @relation("BuddyResponder", fields: [respondedBy], references: [id], onDelete: SetNull)

  @@unique([requesterId, targetId])
  @@map("app_buddy_requests")
}

model BuddyRelation {
  id        String   @id @map("id")
  userAId   String   @map("user_a_id")
  userBId   String   @map("user_b_id")
  createdAt DateTime @db.Timestamptz(6) @map("created_at")
  userA     AppUser  @relation("BuddyUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     AppUser  @relation("BuddyUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@map("app_buddy_relations")
}

model AppPost {
  id               String                   @id @map("id")
  authorId         String                   @map("author_id")
  caption          String                   @map("caption")
  media            Json                     @default("[]") @map("media")
  tags             Json                     @default("[]") @map("tags")
  likes            Int                      @default(0) @map("likes")
  comments         Int                      @default(0) @map("comments")
  shares           Int                      @default(0) @map("shares")
  views            Int                      @default(0) @map("views")
  status           String                   @map("status")
  type             String                   @map("type")
  deletedAt        DateTime?                @db.Timestamptz(6) @map("deleted_at")
  createdAt        DateTime                 @db.Timestamptz(6) @map("created_at")
  author           AppUser                  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reactions        AppPostReaction[]
  commentsList     AppPostComment[]
  bookmarks        Bookmark[]
  collectionItems  CollectionItem[]
  reports          UserReport[]
  scheduledPosts   ScheduledPost[]

  @@index([authorId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("app_posts")
}

model AppPostReaction {
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  reaction  String   @map("reaction")
  createdAt DateTime @db.Timestamptz(6) @map("created_at")
  post      AppPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@map("app_post_reactions")
}

model AppPostComment {
  id           String                    @id @map("id")
  postId       String                    @map("post_id")
  authorId     String?                   @map("author_id")
  authorName   String                    @map("author")
  message      String                    @map("message")
  replyTo      String?                   @map("reply_to")
  createdAt    DateTime                  @db.Timestamptz(6) @map("created_at")
  likeCount    Int                       @default(0) @map("like_count")
  isLikedByMe  Boolean                   @default(false) @map("is_liked_by_me")
  isReported   Boolean                   @default(false) @map("is_reported")
  isEdited     Boolean                   @default(false) @map("is_edited")
  mentions     Json                      @default("[]") @map("mentions")
  post         AppPost                   @relation(fields: [postId], references: [id], onDelete: Cascade)
  author       AppUser?                  @relation(fields: [authorId], references: [id], onDelete: SetNull)
  parent       AppPostComment?           @relation("PostCommentReplies", fields: [replyTo], references: [id], onDelete: Cascade)
  replies      AppPostComment[]          @relation("PostCommentReplies")
  reactions    AppPostCommentReaction[]

  @@index([postId, createdAt(sort: Asc)])
  @@map("app_post_comments")
}

model AppPostCommentReaction {
  commentId String         @map("comment_id")
  userId    String         @map("user_id")
  reaction  String         @map("reaction")
  createdAt DateTime       @db.Timestamptz(6) @map("created_at")
  comment   AppPostComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      AppUser        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([commentId, userId])
  @@map("app_post_comment_reactions")
}

model ChatThread {
  id                String                  @id @map("id")
  title             String                  @map("title")
  participantsLabel String                  @map("participants_label")
  flag              String?                 @map("flag")
  summary           String                  @map("summary")
  createdAt         DateTime                @default(now()) @db.Timestamptz(6) @map("created_at")
  participants      ChatThreadParticipant[]
  messages          ChatMessage[]

  @@map("chat_threads")
}

model ChatThreadParticipant {
  threadId   String     @map("thread_id")
  userId     String     @map("user_id")
  createdAt  DateTime   @db.Timestamptz(6) @map("created_at")
  thread     ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user       AppUser    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([threadId, userId])
  @@map("chat_thread_participants")
}

model ChatMessage {
  id               String       @id @map("id")
  threadId         String       @map("thread_id")
  senderId         String       @map("sender_id")
  text             String       @map("text")
  read             Boolean      @default(false) @map("read")
  timestamp        DateTime     @db.Timestamptz(6) @map("timestamp")
  attachments      Json         @default("[]") @map("attachments")
  replyToMessageId String?      @map("reply_to_message_id")
  deliveryState    String       @default("sent") @map("delivery_state")
  kind             String       @default("text") @map("kind")
  mediaPath        String?      @map("media_path")
  thread           ChatThread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender           AppUser      @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyToMessage   ChatMessage? @relation("MessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies          ChatMessage[] @relation("MessageReplies")

  @@index([threadId, timestamp(sort: Asc)])
  @@map("chat_messages")
}

model AppNotification {
  id          String   @id @map("id")
  recipientId String   @map("recipient_id")
  title       String   @map("title")
  body        String   @map("body")
  createdAt   DateTime @db.Timestamptz(6) @map("created_at")
  read        Boolean  @default(false) @map("read")
  type        String   @map("type")
  routeName   String   @map("route_name")
  entityId    String?  @map("entity_id")
  metadata    Json     @default("{}") @map("metadata")
  recipient   AppUser  @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, createdAt(sort: Desc)])
  @@map("app_notifications")
}

model Story {
  id               String           @id @map("id")
  userId           String           @map("user_id")
  media            String           @default("") @map("media")
  mediaItems       Json             @default("[]") @map("media_items")
  isLocalFile      Boolean          @default(false) @map("is_local_file")
  text             String           @default("") @map("text")
  music            String?          @map("music")
  backgroundColors Json             @default("[]") @map("background_colors")
  textColorValue   BigInt           @default(4294967295) @map("text_color_value")
  sticker          String?          @map("sticker")
  effectName       String?          @map("effect_name")
  mentionUsername  String?          @map("mention_username")
  mentionUsernames Json             @default("[]") @map("mention_usernames")
  linkLabel        String?          @map("link_label")
  linkUrl          String?          @map("link_url")
  privacy          String           @default("public") @map("privacy")
  location         String?          @map("location")
  collageLayout    String?          @map("collage_layout")
  textOffsetDx     Float            @default(0) @map("text_offset_dx")
  textOffsetDy     Float            @default(0) @map("text_offset_dy")
  textScale        Float            @default(1) @map("text_scale")
  mediaTransforms  Json             @default("[]") @map("media_transforms")
  seen             Boolean          @default(false) @map("seen")
  deletedAt        DateTime?        @db.Timestamptz(6) @map("deleted_at")
  createdAt        DateTime         @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt        DateTime         @default(now()) @db.Timestamptz(6) @map("updated_at")
  expiresAt        DateTime         @db.Timestamptz(6) @map("expires_at")
  user             AppUser          @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments         StoryComment[]
  reactions        StoryReaction[]
  views            StoryView[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([expiresAt])
  @@map("app_stories")
}

model StoryComment {
  id        String   @id @map("id")
  storyId   String   @map("story_id")
  userId    String   @map("user_id")
  comment   String   @map("comment")
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([storyId, createdAt(sort: Asc)])
  @@map("app_story_comments")
}

model StoryReaction {
  storyId   String   @map("story_id")
  userId    String   @map("user_id")
  reaction  String   @map("reaction")
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([storyId, userId])
  @@map("app_story_reactions")
}

model StoryView {
  storyId  String   @map("story_id")
  userId   String   @map("user_id")
  viewedAt DateTime @default(now()) @db.Timestamptz(6) @map("viewed_at")
  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user     AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([storyId, userId])
  @@map("app_story_views")
}

model Reel {
  id              String         @id @map("id")
  userId          String         @map("user_id")
  caption         String         @default("") @map("caption")
  audioName       String         @default("") @map("audio_name")
  thumbnailUrl    String         @default("") @map("thumbnail_url")
  videoUrl        String         @default("") @map("video_url")
  textOverlays    Json           @default("[]") @map("text_overlays")
  subtitleEnabled Boolean        @default(false) @map("subtitle_enabled")
  trimInfo        String?        @map("trim_info")
  remixEnabled    Boolean        @default(false) @map("remix_enabled")
  isDraft         Boolean        @default(false) @map("is_draft")
  likesCount      Int            @default(0) @map("likes_count")
  commentsCount   Int            @default(0) @map("comments_count")
  sharesCount     Int            @default(0) @map("shares_count")
  viewsCount      Int            @default(0) @map("views_count")
  deletedAt       DateTime?      @db.Timestamptz(6) @map("deleted_at")
  createdAt       DateTime       @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt       DateTime       @default(now()) @db.Timestamptz(6) @map("updated_at")
  user            AppUser        @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments        ReelComment[]
  reactions       ReelReaction[]
  bookmarks       Bookmark[]
  collectionItems CollectionItem[]

  @@index([userId, createdAt(sort: Desc)])
  @@map("app_reels")
}

model ReelComment {
  id        String   @id @map("id")
  reelId    String   @map("reel_id")
  userId    String   @map("user_id")
  comment   String   @map("comment")
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  reel      Reel     @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([reelId, createdAt(sort: Asc)])
  @@map("app_reel_comments")
}

model ReelReaction {
  reelId    String   @map("reel_id")
  userId    String   @map("user_id")
  reaction  String   @map("reaction")
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  reel      Reel     @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([reelId, userId])
  @@map("app_reel_reactions")
}

model MediaUpload {
  id               String   @id @map("id")
  userId           String?  @map("user_id")
  fileName         String   @map("file_name")
  originalFilename String?  @map("original_filename")
  mimeType         String?  @map("mime_type")
  sizeBytes        BigInt?  @map("size_bytes")
  url              String?  @map("url")
  secureUrl        String?  @map("secure_url")
  publicId         String?  @map("public_id")
  provider         String   @default("cloudinary") @map("provider")
  resourceType     String?  @map("resource_type")
  folder           String?  @map("folder")
  status           String   @default("completed") @map("status")
  metadata         Json     @default("{}") @map("metadata")
  createdAt        DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  user             AppUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@map("app_uploads")
}

model Bookmark {
  id             String             @id @map("id")
  userId         String             @map("user_id")
  entityId       String             @map("entity_id")
  title          String?            @map("title")
  type           String             @default("post") @map("type")
  metadata       Json               @default("{}") @map("metadata")
  createdAt      DateTime           @default(now()) @db.Timestamptz(6) @map("created_at")
  postId         String?            @map("post_id")
  reelId         String?            @map("reel_id")
  productId      String?            @map("product_id")
  collectionId   String?            @map("collection_id")
  user           AppUser            @relation(fields: [userId], references: [id], onDelete: Cascade)
  post           AppPost?           @relation(fields: [postId], references: [id], onDelete: SetNull)
  reel           Reel?              @relation(fields: [reelId], references: [id], onDelete: SetNull)
  product        MarketplaceProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
  collection     Collection?        @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  @@unique([userId, entityId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("app_bookmarks")
}

model Collection {
  id          String           @id @map("id")
  userId      String           @map("user_id")
  title       String           @map("title")
  description String?          @map("description")
  visibility  String           @default("private") @map("visibility")
  createdAt   DateTime         @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt   DateTime         @default(now()) @db.Timestamptz(6) @map("updated_at")
  user        AppUser          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       CollectionItem[]
  bookmarks   Bookmark[]

  @@index([userId, updatedAt(sort: Desc)])
  @@map("app_collections")
}

model CollectionItem {
  id           String              @id @map("id")
  collectionId String              @map("collection_id")
  entityId     String              @map("entity_id")
  entityType   String              @map("entity_type")
  postId       String?             @map("post_id")
  reelId       String?             @map("reel_id")
  productId    String?             @map("product_id")
  createdAt    DateTime            @default(now()) @db.Timestamptz(6) @map("created_at")
  collection   Collection          @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  post         AppPost?            @relation(fields: [postId], references: [id], onDelete: SetNull)
  reel         Reel?               @relation(fields: [reelId], references: [id], onDelete: SetNull)
  product      MarketplaceProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@unique([collectionId, entityId])
  @@map("app_collection_items")
}

model UserBlock {
  actorUserId  String   @map("actor_user_id")
  targetUserId String   @map("target_user_id")
  reason       String?  @map("reason")
  createdAt    DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  actor        AppUser  @relation("BlockActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  target       AppUser  @relation("BlockTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@id([actorUserId, targetUserId])
  @@map("app_user_blocks")
}

model UserReport {
  id               String              @id @map("id")
  reporterUserId   String              @map("reporter_user_id")
  targetUserId     String?             @map("target_user_id")
  targetEntityId   String?             @map("target_entity_id")
  targetEntityType String?             @map("target_entity_type")
  reason           String              @map("reason")
  details          String?             @map("details")
  status           String              @default("submitted") @map("status")
  postId           String?             @map("post_id")
  createdAt        DateTime            @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt        DateTime            @default(now()) @db.Timestamptz(6) @map("updated_at")
  reporter         AppUser             @relation("ReportReporter", fields: [reporterUserId], references: [id], onDelete: Cascade)
  targetUser       AppUser?            @relation("ReportTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  post             AppPost?            @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([reporterUserId, createdAt(sort: Desc)])
  @@map("app_user_reports")
}

model UserSettings {
  userId     String   @id @map("user_id")
  settings   Json     @default("{}") @map("settings")
  updatedAt  DateTime @default(now()) @db.Timestamptz(6) @map("updated_at")
  user       AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("app_user_settings")
}

model UserPrivacy {
  userId             String   @id @map("user_id")
  profilePrivate     Boolean  @default(false) @map("profile_private")
  activityStatus     Boolean  @default(true) @map("activity_status")
  allowTagging       Boolean  @default(true) @map("allow_tagging")
  allowMentions      Boolean  @default(true) @map("allow_mentions")
  allowReposts       Boolean  @default(true) @map("allow_reposts")
  allowComments      Boolean  @default(true) @map("allow_comments")
  hideSensitive      Boolean  @default(true) @map("hide_sensitive")
  hideLikes          Boolean  @default(false) @map("hide_likes")
  updatedAt          DateTime @default(now()) @db.Timestamptz(6) @map("updated_at")
  user               AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("app_user_privacy")
}

model PostDraft {
  id          String    @id @map("id")
  userId      String    @map("user_id")
  title       String    @map("title")
  type        String    @map("type")
  payload     Json      @default("{}") @map("payload")
  scheduledAt DateTime? @db.Timestamptz(6) @map("scheduled_at")
  status      String    @default("draft") @map("status")
  createdAt   DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt   DateTime  @default(now()) @db.Timestamptz(6) @map("updated_at")
  user        AppUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledEntries ScheduledPost[]

  @@index([userId, updatedAt(sort: Desc)])
  @@map("app_post_drafts")
}

model ScheduledPost {
  id              String    @id @map("id")
  userId          String    @map("user_id")
  draftId         String?   @map("draft_id")
  postId          String?   @map("post_id")
  scheduledFor    DateTime  @db.Timestamptz(6) @map("scheduled_for")
  status          String    @default("pending") @map("status")
  retryCount      Int       @default(0) @map("retry_count")
  lastError       String?   @map("last_error")
  createdAt       DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt       DateTime  @default(now()) @db.Timestamptz(6) @map("updated_at")
  user            AppUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  draft           PostDraft? @relation(fields: [draftId], references: [id], onDelete: SetNull)
  post            AppPost?  @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([userId, scheduledFor(sort: Asc)])
  @@map("app_scheduled_posts")
}

model MarketplaceProduct {
  id            String             @id @map("id")
  sellerId      String             @map("seller_id")
  title         String             @map("title")
  description   String             @map("description")
  price         Decimal            @db.Decimal(12, 2) @map("price")
  currency      String             @default("BDT") @map("currency")
  category      String             @map("category")
  subcategory   String?            @map("subcategory")
  condition     String?            @map("condition")
  location      String?            @map("location")
  images        Json               @default("[]") @map("images")
  status        String             @default("active") @map("status")
  stock         Int                @default(1) @map("stock")
  watchers      Int                @default(0) @map("watchers")
  views         Int                @default(0) @map("views")
  deletedAt     DateTime?          @db.Timestamptz(6) @map("deleted_at")
  createdAt     DateTime           @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt     DateTime           @default(now()) @db.Timestamptz(6) @map("updated_at")
  seller        AppUser            @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  orders        MarketplaceOrder[]
  bookmarks     Bookmark[]
  collectionItems CollectionItem[]

  @@index([sellerId, createdAt(sort: Desc)])
  @@index([category, createdAt(sort: Desc)])
  @@map("app_marketplace_products")
}

model MarketplaceOrder {
  id             String             @id @map("id")
  productId      String             @map("product_id")
  buyerId        String             @map("buyer_id")
  sellerId       String             @map("seller_id")
  amount         Decimal            @db.Decimal(12, 2) @map("amount")
  currency       String             @default("BDT") @map("currency")
  address        String             @map("address")
  deliveryMethod String             @map("delivery_method")
  paymentMethod  String             @map("payment_method")
  status         String             @default("pending") @map("status")
  metadata       Json               @default("{}") @map("metadata")
  createdAt      DateTime           @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt      DateTime           @default(now()) @db.Timestamptz(6) @map("updated_at")
  product        MarketplaceProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyer          AppUser            @relation("OrderBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller         AppUser            @relation("OrderSeller", fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([buyerId, createdAt(sort: Desc)])
  @@index([sellerId, createdAt(sort: Desc)])
  @@map("app_marketplace_orders")
}

model Job {
  id               String           @id @map("id")
  recruiterId      String           @map("recruiter_id")
  title            String           @map("title")
  company          String           @map("company")
  description      String           @map("description")
  location         String?          @map("location")
  type             String           @map("type")
  experienceLevel  String?          @map("experience_level")
  salaryMin        Int?             @map("salary_min")
  salaryMax        Int?             @map("salary_max")
  currency         String           @default("BDT") @map("currency")
  status           String           @default("open") @map("status")
  skills           Json             @default("[]") @map("skills")
  metadata         Json             @default("{}") @map("metadata")
  deletedAt        DateTime?        @db.Timestamptz(6) @map("deleted_at")
  createdAt        DateTime         @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt        DateTime         @default(now()) @db.Timestamptz(6) @map("updated_at")
  recruiter        AppUser          @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  applications     JobApplication[]

  @@index([recruiterId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@map("app_jobs")
}

model JobApplication {
  id            String   @id @map("id")
  jobId         String   @map("job_id")
  applicantId   String   @map("applicant_id")
  applicantName String   @map("applicant_name")
  coverLetter   String?  @map("cover_letter")
  resumeUrl     String?  @map("resume_url")
  status        String   @default("submitted") @map("status")
  metadata      Json     @default("{}") @map("metadata")
  createdAt     DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt     DateTime @default(now()) @db.Timestamptz(6) @map("updated_at")
  job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicant     AppUser  @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([jobId, applicantId])
  @@index([applicantId, createdAt(sort: Desc)])
  @@map("app_job_applications")
}

model Event {
  id            String      @id @map("id")
  organizerId   String      @map("organizer_id")
  title         String      @map("title")
  organizerName String      @map("organizer_name")
  description   String?     @map("description")
  date          String      @map("date")
  time          String      @map("time")
  location      String      @map("location")
  category      String?     @map("category")
  participants  Int         @default(0) @map("participants")
  price         Decimal     @default(0) @db.Decimal(12, 2) @map("price")
  status        String      @default("review") @map("status")
  savedCount    Int         @default(0) @map("saved_count")
  deletedAt     DateTime?   @db.Timestamptz(6) @map("deleted_at")
  createdAt     DateTime    @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt     DateTime    @default(now()) @db.Timestamptz(6) @map("updated_at")
  organizer     AppUser     @relation("EventOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  rsvps         EventRsvp[]

  @@index([organizerId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@map("app_events")
}

model EventRsvp {
  eventId    String   @map("event_id")
  userId     String   @map("user_id")
  status     String   @default("going") @map("status")
  saved      Boolean  @default(false) @map("saved")
  createdAt  DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt  DateTime @default(now()) @db.Timestamptz(6) @map("updated_at")
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user       AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([eventId, userId])
  @@map("app_event_rsvps")
}

model Community {
  id                String            @id @map("id")
  ownerId           String            @map("owner_id")
  ownerName         String            @map("owner_name")
  name              String            @map("name")
  description       String            @map("description")
  privacy           String            @default("public") @map("privacy")
  category          String?           @map("category")
  location          String?           @map("location")
  tags              Json              @default("[]") @map("tags")
  rules             Json              @default("[]") @map("rules")
  links             Json              @default("[]") @map("links")
  contactInfo       String?           @map("contact_info")
  coverColors       Json              @default("[]") @map("cover_colors")
  avatarColor       Int?              @map("avatar_color")
  approvalRequired  Boolean           @default(false) @map("approval_required")
  allowEvents       Boolean           @default(true) @map("allow_events")
  allowLive         Boolean           @default(false) @map("allow_live")
  allowPolls        Boolean           @default(true) @map("allow_polls")
  allowMarketplace  Boolean           @default(false) @map("allow_marketplace")
  allowChatRoom     Boolean           @default(true) @map("allow_chat_room")
  notificationLevel String            @default("all") @map("notification_level")
  memberCount       Int               @default(0) @map("member_count")
  deletedAt         DateTime?         @db.Timestamptz(6) @map("deleted_at")
  createdAt         DateTime          @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt         DateTime          @default(now()) @db.Timestamptz(6) @map("updated_at")
  owner             AppUser           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members           CommunityMember[]

  @@index([ownerId, createdAt(sort: Desc)])
  @@map("app_communities")
}

model CommunityMember {
  communityId String     @map("community_id")
  userId      String     @map("user_id")
  role        String     @default("member") @map("role")
  status      String     @default("active") @map("status")
  createdAt   DateTime   @default(now()) @db.Timestamptz(6) @map("created_at")
  community   Community  @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        AppUser    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([communityId, userId])
  @@map("app_community_members")
}

model Subscription {
  id               String   @id @map("id")
  userId           String   @map("user_id")
  planCode         String   @map("plan_code")
  provider         String   @map("provider")
  providerRef      String?  @map("provider_ref")
  status           String   @default("active") @map("status")
  currentPeriodEnd DateTime? @db.Timestamptz(6) @map("current_period_end")
  autoRenew        Boolean  @default(true) @map("auto_renew")
  metadata         Json     @default("{}") @map("metadata")
  createdAt        DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt        DateTime @default(now()) @db.Timestamptz(6) @map("updated_at")
  user             AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("app_subscriptions")
}
