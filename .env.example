DATABASE_URL=postgresql://postgres:postgres@localhost:5432/socity_backend?sslmode=disable
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
AUTH_EXPOSE_TEST_ACCOUNTS=false
ADMIN_EXPOSE_DEMO_ACCOUNTS=false
ADMIN_EXPOSE_TEST_ACCOUNTS=false
ADMIN_BOOTSTRAP_EMAIL=admin@optizenqor.app
ADMIN_BOOTSTRAP_PASSWORD=admin123
ADMIN_BOOTSTRAP_NAME=Super Admin
ADMIN_BOOTSTRAP_ROLE=Super Admin

SESSION_ACCESS_EXPIRES_IN=1h
SESSION_REFRESH_EXPIRES_IN=30d
JWT_SECRET=replace_with_long_random_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password_or_app_password
SMTP_FROM=no-reply@example.com
SMTP_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=
SUPPORT_CONTACT_EMAIL=support@optizenqor.app
SUPPORT_ESCALATION_EMAIL=trust@optizenqor.app
SUPPORT_RESPONSE_TIME=Usually within 24 hours

FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4173

UPLOAD_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
